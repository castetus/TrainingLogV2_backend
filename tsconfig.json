{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "ES2022",
    // "module": "NodeNext",
    // "moduleResolution": "NodeNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": "./src"
  }
}